{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // The data-refresh scripts (scripts/refresh/*) import sibling .ts modules
    // with explicit extensions, which is what Node's native type-stripping
    // requires at runtime; allow tsc to resolve them too (safe under --noEmit).
    "allowImportingTsExtensions": true,
    // tsc is type-check only here (the build is Vite/esbuild), so emitting is
    // never wanted; this also satisfies allowImportingTsExtensions above.
    "noEmit": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": false,
    "types": ["vite/client", "node"]
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "worker/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
