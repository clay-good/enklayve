{
  "name": "enklayve",
  "version": "0.1.0",
  "private": true,
  "description": "Your private financial enclave. Every number is computed on your device. Nothing is ever sent anywhere.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run",
    "audit": "node scripts/audit-release.ts",
    "data:manifest": "node scripts/build-manifest.ts",
    "golden:regen": "REGEN_GOLDEN=1 vitest run tests/golden/snapshot.test.ts",
    "og:image": "node scripts/og-image.ts"
  },
  "dependencies": {
    "decimal.js": "^10.4.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
    "tesseract.js": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.12.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "axe-core": "^4.11.4",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "happy-dom": "^20.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  }
}
